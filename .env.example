# .env.example

# Database
# Exemplo para PostgreSQL: postgresql://USER:PASSWORD@HOST:PORT/DATABASE?schema=public
DATABASE_URL="postgresql://johndoe:randompassword@localhost:5432/hackcoda?schema=public"

# Next Auth
# Gere um segredo usando: openssl rand -base64 32
NEXTAUTH_SECRET="your_nextauth_secret_here"
NEXTAUTH_URL="http://localhost:3000"

