generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  USER
  ADMIN
}

enum HackathonStatus {
  DRAFT
  PUBLISHED
  ACTIVE
  FINISHED
  CANCELLED
}

enum ProjectStatus {
  DRAFT
  SUBMITTED
}

model User {
  id        String   @id @default(uuid())
  email     String   @unique
  name      String
  photo     String?
  password  String
  role      Role     @default(USER)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  hackathons Hackathon[]

  @@map("users")
}

model Hackathon {
  id                   String          @id @default(uuid())
  title                String          @unique
  description          String
  rules                String?
  bannerUrl            String?
  maxTeamSize          Int
  registrationDeadline DateTime
  startDate            DateTime
  endDate              DateTime
  status               HackathonStatus @default(DRAFT)
  createdBy            String
  createdAt            DateTime        @default(now())
  updatedAt            DateTime        @updatedAt

  creator  User      @relation(fields: [createdBy], references: [id])
  teams    Team[]
  rankings Ranking[]

  @@map("hackathons")
}

model Team {
  id          String   @id @default(uuid())
  name        String
  description String?
  hackathonId String
  leaderId    String
  inviteCode  String   @unique
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  hackathon Hackathon @relation(fields: [hackathonId], references: [id])
  projects  Project[]

  @@unique([name, hackathonId])
  @@map("teams")
}

model Project {
  id          String        @id @default(uuid())
  name        String
  description String
  teamId      String
  repoUrl     String?
  demoUrl     String?
  techStack   String[]
  status      ProjectStatus @default(DRAFT)
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  team    Team     @relation(fields: [teamId], references: [id])
  ranking Ranking?

  @@unique([name, teamId])
  @@map("projects")
}

model Ranking {
  id          String    @id @default(uuid())
  projectId   String    @unique
  hackathonId String
  score       Float     @default(0)
  position    Int
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  project   Project   @relation(fields: [projectId], references: [id])
  hackathon Hackathon @relation(fields: [hackathonId], references: [id])

  @@unique([hackathonId, position])
  @@map("rankings")
}
